# ── Paths (no trailing slash) ──────────────────────────────────────────────
AGENT_ROOT=D:/mcp/agent
WORKSPACE_ROOT=D:/mcp/agent/workspace
MEMORY_ROOT=D:/mcp/agent/memory_db

# ── LM Studio ──────────────────────────────────────────────────────────────
LM_STUDIO_BASE_URL=http://localhost:1234/v1
FASTMCP_LOG_LEVEL=error

# ── Provider Configurations ─────────────────────────────────────────────────
# Format: {PROVIDER}_API_KEY, {PROVIDER}_BASE_URL, {PROVIDER}_BASE_MODEL
# Add as many as you want. No code changes needed.
# (Comment out the API key to completely disable that provider)

# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_BASE_MODEL=gpt-4o-mini

# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_BASE_MODEL=deepseek-chat

# MISTRAL_API_KEY=...
# MISTRAL_BASE_URL=https://api.mistral.ai/v1
# MISTRAL_BASE_MODEL=mistral-large-latest

# QWEN_API_KEY=sk-...
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_BASE_MODEL=qwen-turbo

# KIMI_API_KEY=sk-...
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_BASE_MODEL=moonshot-v1-8k

# ── Model Roles ───────────────────────────────────────────────────────────
# CRITICAL: You can set these to EITHER:
#   1. A local model name (e.g., "qwen-qwen3.5-9b", "granite-4.0-h-tiny@q2_k") 
#      → This will automatically route to your local LM Studio.
#   2. An exact provider name (e.g., "openai", "deepseek", "qwen", "kimi", "mistral") 
#      → This will automatically route to that provider's BASE_URL and use its BASE_MODEL.

PLANNER_MODEL=qwen_qwen3.5-9b

# ── Per-Role Overrides (optional) ─────────────────────────────────────────
EXECUTOR_MODEL=granite-4.0-h-tiny@q2_k
# Executor group (fallback: EXECUTOR_MODEL → PLANNER_MODEL)
SUMMARIZE_MODEL=
EXTRACT_MODEL=
RESEARCH_MODEL=
CRITIQUE_MODEL=
ANALYZE_MODEL=
CODE_MODEL=
REVIEW_MODEL=

ROUTER_MODEL=granite-4.0-350m
# Router group (fallback: ROUTER_MODEL → PLANNER_MODEL)
CLASSIFY_MODEL=
ROUTE_MODEL=

# Vision (fallback: VISION_MODEL → PLANNER_MODEL)
VISION_MODEL=

# ── Consultor Role ────────────────────────────────────────────────────────
# Follows the exact same dual-routing rules as Model Roles above.
# Examples: 
#   CONSULTOR_MODEL=openai       (Uses OPENAI_BASE_MODEL via OpenAI API)
#   CONSULTOR_MODEL=deepseek     (Uses DEEPSEEK_BASE_MODEL via DeepSeek API)
#   CONSULTOR_MODEL=qwen-3b      (Routes to local LM Studio)
# 
# Leave completely blank (CONSULTOR_MODEL=) to disable the consultor role entirely.
CONSULTOR_MODEL=

# ── External services ──────────────────────────────────────────────────────
SEARXNG_URL=http://localhost:8080

# ── Memory tuning ────────────────────────────────────────────────────────────
MEMORY_DELETE_THRESHOLD=0.4
MEMORY_DECAY_DAYS=30
MEMORY_TOP_K=5

# ── Execution ──────────────────────────────────────────────────────────────
EXECUTION_TIMEOUT=180

# ── Autocode ────────────────────────────────────────────────────────────────
AUTOCODE_MAX_RETRIES=3
AUTOCODE_MAX_FILE_CHARS=6000
AUTOCODE_DEBUG=0

# ── Gateway ─────────────────────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_SECRET=changeme     # needs to be changed in production for security

# ── Environment ────────────────────────────────────────────────────────────
ENV=development

# =============================================================================
# SSRF Protection Configuration
# =============================================================================
# Comma-separated list of hostnames allowed for internal service access
# 
# DEVELOPMENT DEFAULT: "localhost,127.0.0.1,::1"
#   - Required for local tools: SearXNG (localhost:3000), LM Studio (127.0.0.1:1234)
#   - Warning logged on startup if permissive default is active
#
# PRODUCTION RECOMMENDED: "" (empty string)
#   - Blocks ALL localhost/private/localhost URLs for maximum security
#   - Use only if agent doesn't need to access local services
#
# CUSTOM ALLOWLIST EXAMPLE:
#   ALLOWED_INTERNAL_HOSTS="searxng.internal,local-lm-studio,10.0.0.50"
#
ALLOWED_INTERNAL_HOSTS=localhost,127.0.0.1,::1