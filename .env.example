# ── Paths (no trailing slash) ──────────────────────────────────────────────
AGENT_ROOT=D:/mcp/agent
WORKSPACE_ROOT=D:/mcp/agent/workspace
MEMORY_ROOT=D:/mcp/agent/memory_db

# ── LM Studio ──────────────────────────────────────────────────────────────
LM_STUDIO_BASE_URL=http://localhost:1234/v1
FASTMCP_LOG_LEVEL=error

# ── Provider Configurations ─────────────────────────────────────────────────
# Format: {PROVIDER}_API_KEY, {PROVIDER}_BASE_URL, {PROVIDER}_BASE_MODEL
# Add as many as you want. No code changes needed.
# (Comment out the API key to completely disable that provider)

# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_BASE_MODEL=gpt-4o-mini

# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_BASE_MODEL=deepseek-chat

# MISTRAL_API_KEY=...
# MISTRAL_BASE_URL=https://api.mistral.ai/v1
# MISTRAL_BASE_MODEL=mistral-large-latest

# QWEN_API_KEY=sk-...
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_BASE_MODEL=qwen-turbo

# KIMI_API_KEY=sk-...
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_BASE_MODEL=moonshot-v1-8k

# Claude (Anthropic) — NOT OpenAI-compatible, native AnthropicProvider
# CLAUDE_API_KEY=sk-ant-...
# CLAUDE_BASE_URL=https://api.anthropic.com
# CLAUDE_BASE_MODEL=claude-3-5-haiku-20241022

# Gemini (Google) — NOT OpenAI-compatible, native GeminiProvider
# GEMINI_API_KEY=...
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# GEMINI_BASE_MODEL=gemini-2.0-flash

# Z.ai (GLM) — OpenAI-compatible
# ZAI_API_KEY=...
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4
# ZAI_BASE_MODEL=glm-4-flash

# MiMo (Xiaomi AI Studio) — OpenAI-compatible
# MIMO_API_KEY=...
# MIMO_BASE_URL=https://aistudio.xiaomimimo.com/v1
# MIMO_BASE_MODEL=mimo-7b

# ── Model Roles ───────────────────────────────────────────────────────────
# CRITICAL: You can set these to EITHER:
#   1. A local model name (e.g., "qwen-qwen3.5-9b", "granite-4.0-h-tiny@q2_k") 
#      → This will automatically route to your local LM Studio.
#   2. An exact provider name (e.g., "openai", "deepseek", "qwen", "kimi", "mistral") 
#      → This will automatically route to that provider's BASE_URL and use its BASE_MODEL.

# ── Per-Role Overrides (optional) ─────────────────────────────────────────
PLANNER_MODEL=gemma-4-e2b-it@q3_k_xl

EXECUTOR_MODEL=gemma-2-2b-it
# Executor group (fallback: EXECUTOR_MODEL → PLANNER_MODEL)
SUMMARIZE_MODEL=lfm2-1.2b-tool
EXTRACT_MODEL=gemma-2-2b-it
RESEARCH_MODEL=lfm2-1.2b-tool
CRITIQUE_MODEL=lfm2-1.2b-tool
ANALYZE_MODEL=gemma-2-2b-it
CODE_MODEL=gemma-4-e2b-it@q3_k_xl
REVIEW_MODEL=lfm2-1.2b-tool
REFACTOR_MODEL=gemma-4-e2b-it@q3_k_xl
TEST_MODEL=gemma-4-e2b-it@q3_k_xl
DOCUMENT_MODEL=lfm2-1.2b-tool

ROUTER_MODEL=gemma-2-2b-it
# Router group (fallback: ROUTER_MODEL → PLANNER_MODEL)
CLASSIFY_MODEL=gemma-2-2b-it
ROUTE_MODEL=lfm2-1.2b-tool

# Vision (fallback: VISION_MODEL → PLANNER_MODEL)
VISION_MODEL=

# ── Consultor Role ────────────────────────────────────────────────────────
# Follows the exact same dual-routing rules as Model Roles above.
# Examples: 
#   CONSULTOR_MODEL=openai       (Uses OPENAI_BASE_MODEL via OpenAI API)
#   CONSULTOR_MODEL=deepseek     (Uses DEEPSEEK_BASE_MODEL via DeepSeek API)
#   CONSULTOR_MODEL=claude       (Uses CLAUDE_BASE_MODEL via Anthropic API)
#   CONSULTOR_MODEL=gemini       (Uses GEMINI_BASE_MODEL via Google AI API)
#   CONSULTOR_MODEL=zai          (Uses ZAI_BASE_MODEL via Z.ai API)
#   CONSULTOR_MODEL=mimo         (Uses MIMO_BASE_MODEL via MiMo API)
#   CONSULTOR_MODEL=qwen-3b      (Routes to local LM Studio)
# 
# Leave completely blank (CONSULTOR_MODEL=) to disable the consultor role entirely.
CONSULTOR_MODEL=

# ── Codebase Embeddings (understand workflow) ───────────────────────────────
# Download All-MiniLM-L6-v2-Embedding-GGUF (q8, 25MB) in LM Studio,
# load it under Models → Embeddings, then set the model name below to
# match what LM Studio shows. If not loaded, vector indexing is skipped
# gracefully (graph edges still work, just no semantic search).
EMBEDDING_MODEL=text-embedding-all-minilm-l6-v2-embedding
EMBEDDING_BASE_URL=http://localhost:1234/v1
EMBEDDING_ENABLED=true

# ── External services ──────────────────────────────────────────────────────
SEARXNG_URL=http://localhost:8080

# ── GitHub API (for github tool — PR operations, push) ────────────────────
# GITHUB_TOKEN=ghp_...
# GITHUB_OWNER=brunogcar
# GITHUB_REPO=agent

# -- Tavily AI Research (optional - keyless mode supports limited search/extract)
# TAVILY_API_KEY=tvly-...
# TAVILY_TIMEOUT=60

# ── Timezone  ───────────────────────────────────────────────────────
# Single source of truth for tz-aware datetime operations (core/time_utils.py,
# notify_ops, schedule_ops). Empty = use system local timezone.
# Examples: America/Sao_Paulo, Europe/London, UTC.
AGENT_TZ=America/Sao_Paulo

# ── Memory tuning ────────────────────────────────────────────────────────────
MEMORY_DELETE_THRESHOLD=0.4
MEMORY_DECAY_DAYS=30
MEMORY_TOP_K=5

# ── Execution ──────────────────────────────────────────────────────────────
# ── Timezone (v1.0) ───────────────────────────────────────────────────────
# Single source of truth for tz-aware datetime operations (core/time_utils.py,
# notify_ops, schedule_ops). Empty = use system local timezone.
# Examples: America/Sao_Paulo, Europe/London, UTC.
# AGENT_TZ=

EXECUTION_TIMEOUT=180
MAX_CONTEXT_TOKENS=32000

# ── Autocode ────────────────────────────────────────────────────────────────
AUTOCODE_MAX_RETRIES=3
AUTOCODE_MAX_FILE_CHARS=6000
AUTOCODE_DEBUG=0

# ── Subagent Native Tool Calling (v2.1) ─────────────────────────────────────
# When enabled (1), the subagent uses the LLM's native tool-calling API
# (OpenAI tools / Claude tool_use / Gemini functionDeclarations) instead of
# the JSON-parsed ReAct loop. The LLM returns structured tool_calls (not JSON
# with thought/tool_call/final_answer), which is more reliable and eliminates
# an entire class of small-model JSON-formatting bugs.
#
# Default: 0 (JSON-parsed ReAct loop — works with all models, including small
#               local models that don't support native tool calling)
# Set to 1:  use native tool calling (requires a model that supports it —
#            OpenAI GPT-4/4o, Claude 3.5+, Gemini 1.5+, Llama 3.1+, Qwen 2.5+)
#
# When to use native:
#   - You're using a cloud LLM (OpenAI/Claude/Gemini) — always enable
#   - You're using a local model that supports tool calling — enable + test
#   - You're using a small/old local model — leave at 0 (JSON path is the fallback)
#
# Safety: both paths enforce the same _ALLOWED_SUBAGENT_ACTIONS security boundary
# (read-only tools only: file.read, git.status, web.search, memory.recall, etc.)
SUBAGENT_NATIVE_TOOLS=0

# ── Gateway ─────────────────────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_SECRET=changeme     # needs to be changed in production for security

# -- Deep Research Workflow ----------------------------------------------------
DEEP_RESEARCH_MAX_ITERATIONS=10          # Hard cap before forced exit
DEEP_RESEARCH_COMPLETENESS_THRESHOLD=85  # 0-100, exit if score >= this AND converged
DEEP_RESEARCH_MAX_API_CALLS=20           # Tavily search/extract budget per workflow
DEEP_RESEARCH_MAX_BROWSER_ACTIONS=10     # Browser nav/interact budget per workflow
DEEP_RESEARCH_TIMEOUT_SECONDS=300        # Overall workflow timeout

# ── Environment ────────────────────────────────────────────────────────────
ENV=development
DISABLE_MODEL_WARMUP=0  # Set to 1 to skip model warmup on startup

# =============================================================================
# SSRF Protection Configuration
# =============================================================================
# Comma-separated list of hostnames allowed for internal service access
# 
# DEVELOPMENT DEFAULT: "localhost,127.0.0.1,::1"
#   - Required for local tools: SearXNG (localhost:3000), LM Studio (127.0.0.1:1234)
#   - Warning logged on startup if permissive default is active
#
# PRODUCTION RECOMMENDED: "" (empty string)
#   - Blocks ALL localhost/private/localhost URLs for maximum security
#   - Use only if agent doesn't need to access local services
#
# CUSTOM ALLOWLIST EXAMPLE:
#   ALLOWED_INTERNAL_HOSTS="searxng.internal,local-lm-studio,10.0.0.50"
#
ALLOWED_INTERNAL_HOSTS=localhost,127.0.0.1,::1