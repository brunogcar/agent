"""Amend – change the message of the most recent commit without altering its content."""

from ._base import register_git
from ._helpers import _git, _check_repo

HELP_AMEND = """\\\
amend
    Amend the last commit with a new message. Used to fix wrong commit messages
    or add missing files to the previous commit. 
    ⚠️ Only works on local repos; does not affect pushed history until force-push.
    
    Required: message (new commit message)
    Optional: root (repository path)
    
    Returns: {status: "amended" | "error", commit_hash, old_commit_hash}
    
    Examples:
      git(operation="amend", message="fix(b3_cvm): unzip B3 ISIN file before parsing...")
"""

@register_git(
    name="amend",
    help_text=HELP_AMEND,
    needs_repo=True,
    examples=[
        'git(operation="amend", message="fix: update commit message from wrong version")',
    ],
)
def run_amend(cwd, message: str = "", **kwargs) -> dict:
    if not message:
        return {"status": "error", "error": "message is required for amend"}

    ok, err = _check_repo(cwd)
    if not ok:
        return {"status": "error", "error": err}

    # Get the current HEAD hash (old commit we want to replace)
    head_hash, _, _ = _git(["rev-parse", "HEAD"], cwd)
    
    # Check if there are unstaged/untracked files that would be included
    status_out, _, status_err = _git(["status", "--porcelain"], cwd)
    
    # Soft reset to HEAD~1 - move back one commit but keep changes in working tree
    code, _, err = _git(["reset", "--soft", "HEAD~1"], cwd)
    if code != 0:
        return {"status": "error", "error": f"reset failed: {err}"}
    
    # Stage all modified files
    add_out, _, add_err = _git(["add", "."], cwd)
    if add_out and add_err:
        # Don't fail if nothing to add, but warn
        pass
    
    # Amend the commit with new message
    amend_code, amend_out, amend_err = _git(
        ["commit", "--amend", "-m", message],
        cwd
    )
    
    if amend_code != 0:
        if "no changes to commit" in amend_err.lower():
            # Commit was already clean with no new changes
            return {
                "status": "error", 
                "error": "Nothing to amend - commit is already clean. Use --no-verify or add changes first.",
                "old_commit_hash": head_hash.strip()
            }
        return {"status": "error", "error": f"amend failed: {amend_err}"}
    
    # Get new commit hash
    new_head, _, _ = _git(["rev-parse", "--short", "HEAD"], cwd)
    
    return {
        "status": "amended", 
        "commit_hash": new_head,
        "old_commit_hash": head_hash.strip()
    }
