{
  "mcpServers": {
    "agent": {
      "command": "python",
      "args": ["D:/mcp/agent/server.py"],
      "cwd": "D:/mcp/agent",
      "env": {}
    },
    "fs": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "D:/mcp/workspace",
        "D:/mcp/agent"
      ]
    },
    "git": {
      "command": "npx",
      "args": ["-y", "@cyanheads/git-mcp-server@latest"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio",
        "MCP_LOG_LEVEL": "error",
        "GIT_BASE_DIR": "D:/mcp/agent"
      }
    },
    "time": {
      "command": "npx",
      "args": ["-y", "@mcpcentral/mcp-time"]
    }
  }
}
