{
  "mcpServers": {
    "agent": {
      "command": "D:/mcp/agent/venv/Scripts/python.exe",
      "args": [
        "D:/mcp/agent/server.py"
      ],
      "cwd": "D:/mcp/agent",
      "env": {}
    },
    "fs": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "D:/mcp/agent"
      ]
    },
    "time": {
      "command": "npx",
      "args": [
        "-y",
        "@mcpcentral/mcp-time"
      ]
    }
  }
}